# Server
PORT=3000
NODE_ENV=production

# Admin credentials (used on first start to seed the admin account)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# JWT secret for admin sessions
JWT_SECRET=replace-with-a-long-random-string

# Storage paths (inside container)
DATA_DIR=/data
UPLOAD_DIR=/data/uploads
DB_PATH=/data/fileshare.db

# Limits
MAX_UPLOAD_BYTES=2147483648     # 2 GiB per file
MAX_STORAGE_BYTES=10737418240   # 10 GiB total across all uploads
MAX_LIFETIME_DAYS=30
