# Server
PORT=3000
NODE_ENV=production

# Admin credentials (used on first start to seed the admin account)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# JWT secret for admin sessions
JWT_SECRET=replace-with-a-long-random-string

# Storage paths (inside container)
DATA_DIR=/data
UPLOAD_DIR=/data/uploads
DB_PATH=/data/fileshare.db

# Limits
MAX_UPLOAD_BYTES=2147483648     # 2 GiB per file
# Hard ceiling on total storage used by the app, in bytes.
# 0 = no ceiling: the app uses whatever the host filesystem can spare.
MAX_STORAGE_BYTES=0

# Per-user limits are configured per account in the admin UI:
#  - max_lifetime_days: 0 = no limit (admin default), 14 = default for new users
#  - max_storage_bytes: 0 = use the system pool, otherwise a per-user cap
